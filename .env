# ================================================
# Theme Management Server — Environment Variables
# ================================================

# MongoDB Connection URL (use same Atlas cluster or separate DB)
MONGODB_URI=mongodb+srv://gkd:gkd785625%40Kd02@cluster0.hxh3fpj.mongodb.net/theme_server

# JWT Secret — use a long random string (different from school-management)
JWT_SECRET=theme_server_super_secret_jwt_key_2026_change_this

# JWT Expiry
JWT_EXPIRY=7d

# Fallback JWT Secret from school-management Next.js app to verify parent login tokens
JWT_ACCESS_SECRET=change_this_to_a_very_long_random_secret_key_access

# Bcrypt Rounds (10-12 recommended for production)
BCRYPT_ROUNDS=12

# Server Port
PORT=4000

# Allowed CORS origins (comma separated — add your Vercel URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://grayschoolmanagment.vercel.app
